{
  "name": "notion-content-gen",
  "version": "0.0.2",
  "description": "CLI tool that fetches a Notion page tree (or wiki) and writes each page as a static file on disk, preserving the Notion hierarchy as nested directories.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruanswanepoel/notion-content-gen.git"
  },
  "homepage": "https://github.com/ruanswanepoel/notion-content-gen#readme",
  "bugs": {
    "url": "https://github.com/ruanswanepoel/notion-content-gen/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "notion-content-gen": "./dist/bin/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "default": "./dist/src/types.js"
    },
    "./plugins/assets": {
      "types": "./dist/src/plugins/assets.d.ts",
      "default": "./dist/src/plugins/assets.js"
    },
    "./plugins/frontmatter": {
      "types": "./dist/src/plugins/frontmatter.d.ts",
      "default": "./dist/src/plugins/frontmatter.js"
    },
    "./plugins/mdx-blocks": {
      "types": "./dist/src/plugins/mdx_blocks.d.ts",
      "default": "./dist/src/plugins/mdx_blocks.js"
    },
    "./presets/fumadocs": {
      "types": "./dist/src/presets/fumadocs.d.ts",
      "default": "./dist/src/presets/fumadocs.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build": "tsc",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build"
  },
  "keywords": [
    "notion",
    "notion-to-md",
    "static-site",
    "content",
    "cli"
  ],
  "author": "Ruan Swanepoel",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@notionhq/client": "^5.4.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "notion-to-md": "^3.1.9",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
